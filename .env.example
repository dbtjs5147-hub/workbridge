# ============================================================
# WorkBridge 환경 변수 예시
# 이 파일을 복사해서 ".env" 파일을 만들면 됩니다.
# (실제 비밀 값은 .env 에만 넣고, 절대 깃에 올리지 마세요)
# ============================================================

# --- 데이터베이스 (PostgreSQL) ---
# 로컬·운영 모두 PostgreSQL을 사용합니다. Neon에서 만든 연결 URL을 넣으세요.
# Neon: 프로젝트 생성 후 화면의 "Connection string"(Pooled, 주소에 -pooler 포함) 복사.
# (다른 PostgreSQL 제공처여도 연결 URL만 넣으면 동일하게 동작합니다.)
DATABASE_URL="postgresql://사용자:비밀번호@ep-xxxx-pooler.리전.aws.neon.tech/neondb?sslmode=require"

# --- 인증 (JWT) ---
# 로그인 토큰 서명에 쓰이는 비밀 키. 아무 긴 랜덤 문자열이면 됩니다.
JWT_SECRET="change-me-to-a-long-random-string-please-32chars-min"

# --- AI 분석 (LLM) ---
# 비워두면 자동으로 "가짜 분석 데이터(mock)"가 동작합니다.
# 실제 AI를 쓰려면 AI_PROVIDER를 바꾸고 해당 키를 입력하세요. 키가 없거나 실패하면 mock으로 안전 폴백됩니다.
#  - Gemini(권장, 저렴): AI_PROVIDER="gemini" + GEMINI_API_KEY  (https://aistudio.google.com/apikey 에서 발급)
#  - Claude: AI_PROVIDER="anthropic" + ANTHROPIC_API_KEY
#  - OpenAI: AI_PROVIDER="openai" + OPENAI_API_KEY
# 전환 시 프로젝트 분석·PRD 생성·후속질문·변경요청 판단이 모두 해당 모델로 동작합니다.
AI_PROVIDER="mock"          # mock | gemini | anthropic | openai
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"       # 선택: 사용할 Gemini 모델
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"   # 선택: 사용할 Claude 모델
OPENAI_API_KEY=""

# --- 소셜 로그인 (OAuth) ---
# 비워두면 "데모 소셜 로그인"으로 동작합니다.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# --- 결제 (PG: 토스페이먼츠) ---
# 비워두면 "가짜 결제(mock)"로 전체 흐름이 동작합니다(데모).
# 토스 키를 넣으면 실제 결제창 → 서버 승인(/api/payments/confirm) 흐름으로 전환됩니다.
#  - 클라이언트 키는 NEXT_PUBLIC_ 접두사가 있어야 브라우저에 노출됩니다.
#  - 테스트 키는 토스페이먼츠 개발자센터(또는 공식 문서)에서 발급받으세요.
#    실거래(실제 송금)는 사업자등록 + 토스 가맹 계약 후의 '라이브 키'가 필요합니다.
PG_PROVIDER="mock"          # mock | toss
NEXT_PUBLIC_TOSS_CLIENT_KEY=""   # 예: test_ck_... (토스 테스트 클라이언트 키)
TOSS_SECRET_KEY=""               # 예: test_sk_... (토스 테스트 시크릿 키, 서버 전용)

# --- 파일 업로드 (Vercel Blob) ---
# 비워두면 로컬 폴더(public/uploads)에 저장합니다(데모/로컬용, 배포 시엔 휘발).
# 운영(Vercel): Storage → Blob 생성 후 발급되는 토큰을 넣으면 클라우드에 영구 저장됩니다.
BLOB_READ_WRITE_TOKEN=""

# --- 이메일 (가입 인증 / 비밀번호 재설정) ---
# 비워두면 실제 발송 대신 콘솔에 인증/재설정 링크를 출력합니다(개발 폴백).
# 실제 발송하려면 Resend(https://resend.com) 가입 후 API 키를 넣으세요.
#  - EMAIL_FROM 은 Resend에서 인증한 도메인 주소여야 실제 발송됩니다.
#    (테스트는 onboarding@resend.dev 로 본인 메일에만 발송 가능)
RESEND_API_KEY=""
EMAIL_FROM="WorkBridge <onboarding@resend.dev>"

# --- 앱 기본 URL ---
# 운영 배포 시 실제 도메인으로 변경 (예: https://workbridge.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- 플랫폼 정책 ---
PLATFORM_FEE_RATE="0.1"     # 수수료율 10%
