# ============================================================
# WorkBridge 환경 변수 예시
# 이 파일을 복사해서 ".env" 파일을 만들면 됩니다.
# (실제 비밀 값은 .env 에만 넣고, 절대 깃에 올리지 마세요)
# ============================================================

# --- 데이터베이스 ---
# 로컬 개발: SQLite (파일 한 개, 별도 설치 불필요)
DATABASE_URL="file:./dev.db"
# 운영 배포 시 PostgreSQL 예시:
# DATABASE_URL="postgresql://user:password@host:5432/workbridge?schema=public"

# --- 인증 (JWT) ---
# 로그인 토큰 서명에 쓰이는 비밀 키. 아무 긴 랜덤 문자열이면 됩니다.
JWT_SECRET="change-me-to-a-long-random-string-please-32chars-min"

# --- AI 분석 (LLM) ---
# 비워두면 자동으로 "가짜 분석 데이터(mock)"가 동작합니다.
# 실제 Claude를 쓰려면: (1) AI_PROVIDER="anthropic" 로 바꾸고 (2) ANTHROPIC_API_KEY 입력.
# 그러면 프로젝트 분석·PRD 생성·변경요청 판단이 모두 실제 Claude로 전환됩니다.
AI_PROVIDER="mock"          # mock | anthropic | openai
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"   # 선택: 사용할 Claude 모델
OPENAI_API_KEY=""

# --- 소셜 로그인 (OAuth) ---
# 비워두면 "데모 소셜 로그인"으로 동작합니다.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# --- 결제 (PG Sandbox) ---
# 비워두면 "가짜 결제(mock)"로 전체 흐름이 동작합니다.
PG_PROVIDER="mock"          # mock | toss | portone
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""

# --- 앱 기본 URL ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- 플랫폼 정책 ---
PLATFORM_FEE_RATE="0.1"     # 수수료율 10%
